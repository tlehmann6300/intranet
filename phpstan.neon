parameters:
    # Analysis level: 0 (lenient) to 10 (strictest).
    # Raised from 6 → 7 for stricter type checking.
    # Next step: resolve remaining level-7 errors, then bump to 8.
    level: 7

    paths:
        - src
        - includes/handlers
        - includes/services
        - routes

    excludePaths:
        - vendor
        - tests/coverage

    # Suppress errors from third-party code that is not type-annotated
    ignoreErrors:
        # Legacy code may use mixed types – address these incrementally
        - '#Parameter \#[0-9]+ \$[a-zA-Z]+ of function .+ expects .+, mixed given#'
        # PDO::fetchAll returns mixed[] at level 7
        - '#Method .+ return type has no value type specified in iterable type array#'

    # Treat missing return types as errors at higher levels
    checkMissingIterableValueType: false
    checkGenericClassInNonGenericObjectType: false

    # Bootstrap file makes application constants available during analysis
    bootstrapFiles:
        - tests/bootstrap.php
