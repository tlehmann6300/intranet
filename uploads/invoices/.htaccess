# Block all direct HTTP requests – files are served via api/download_invoice_file.php
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>
# Prevent PHP execution as an additional safety measure
php_flag engine off
AddType text/plain .php .php3 .phtml
