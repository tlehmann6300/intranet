# ===========================================================================
# IBC Intranet – Environment Configuration Template
# ===========================================================================
# Copy this file to .env and fill in the values for your environment.
# NEVER commit the actual .env file to version control.
#
# All values without a default MUST be set before the application starts.
# ===========================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
BASE_URL=https://intra.example.com
ENVIRONMENT=production          # "production" | "development"

# ---------------------------------------------------------------------------
# Database – User DB (authentication / profiles)
# ---------------------------------------------------------------------------
DB_USER_HOST=localhost
DB_USER_NAME=intranet_users
DB_USER_USER=db_user
DB_USER_PASS=

# ---------------------------------------------------------------------------
# Database – Content DB (events, documents, job queue, …)
# ---------------------------------------------------------------------------
DB_CONTENT_HOST=localhost
DB_CONTENT_NAME=intranet_content
DB_CONTENT_USER=db_user
DB_CONTENT_PASS=

# ---------------------------------------------------------------------------
# Database – Invoice / Rech DB
# ---------------------------------------------------------------------------
DB_RECH_HOST=localhost
DB_RECH_PORT=3306
DB_RECH_NAME=intranet_rechnungen
DB_RECH_USER=db_user
DB_RECH_PASS=

# ---------------------------------------------------------------------------
# Database – Inventory DB
# ---------------------------------------------------------------------------
DB_INVENTORY_HOST=localhost
DB_INVENTORY_PORT=3306
DB_INVENTORY_NAME=intranet_inventory
DB_INVENTORY_USER=db_user
DB_INVENTORY_PASS=

# ---------------------------------------------------------------------------
# Database – News DB
# ---------------------------------------------------------------------------
DB_NEWS_HOST=localhost
DB_NEWS_NAME=intranet_news
DB_NEWS_USER=db_user
DB_NEWS_PASS=

# ---------------------------------------------------------------------------
# Database – vCard DB (external hosting)
# ---------------------------------------------------------------------------
DB_VCARD_HOST=db5016986508.hosting-data.io
DB_VCARD_PORT=3306
DB_VCARD_NAME=dbs13688083
DB_VCARD_USER=dbu5428642
DB_VCARD_PASS=                   # REQUIRED – no default

# ---------------------------------------------------------------------------
# SMTP (outgoing mail)
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=
SMTP_FROM=noreply@example.com
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME="IBC Intranet"

# ---------------------------------------------------------------------------
# Microsoft Azure / Entra ID (SSO)
# ---------------------------------------------------------------------------
AZURE_TENANT_ID=                 # REQUIRED
AZURE_CLIENT_ID=                 # REQUIRED
AZURE_CLIENT_SECRET=             # REQUIRED – keep secret
AZURE_REDIRECT_URI=https://intra.example.com/auth/callback

# ---------------------------------------------------------------------------
# Mail recipients
# ---------------------------------------------------------------------------
SUPPORT_EMAIL=it@example.com
IT_Mail=it@example.com           # fallback for SUPPORT_EMAIL and IT_RESSORT_MAIL
IT_RESSORT_MAIL=it@example.com
IDEAS_EMAIL=ideas@example.com
FINANCE_EMAIL=finance@example.com
INVENTORY_EMAIL=inventory@example.com
INVOICE_NOTIFICATION_EMAIL=vorstand@example.com
INVENTORY_BOARD_EMAIL=vorstand@example.com

# ---------------------------------------------------------------------------
# EasyVerein integration
# ---------------------------------------------------------------------------
EASYVEREIN_API_TOKEN=            # REQUIRED for member sync

# ---------------------------------------------------------------------------
# Cron security token
# Used to authenticate HTTP-triggered cron requests (?token=…)
# Generate with: php -r "echo bin2hex(random_bytes(32));"
# ---------------------------------------------------------------------------
CRON_TOKEN=                      # REQUIRED – long random secret

# ---------------------------------------------------------------------------
# Google reCAPTCHA v2
# ---------------------------------------------------------------------------
RECAPTCHA_SITE_KEY=6LfvX4ssAAAAAJDjL5xtcpXkjbRww5FRtHC1DYqX
RECAPTCHA_SECRET_KEY=            # REQUIRED

# ---------------------------------------------------------------------------
# Trusted reverse-proxy IP addresses (comma-separated)
# X-Forwarded-For is only honoured from these IPs.
# Leave empty if there is no reverse proxy in front of PHP.
# ---------------------------------------------------------------------------
TRUSTED_PROXIES=

# ---------------------------------------------------------------------------
# Rental
# ---------------------------------------------------------------------------
INTRA_RENTAL_USER_NAME="Intra Ausleihe"
