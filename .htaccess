Options -Indexes

# Security: Deny access to sensitive files
# Covers environment config, secrets, lock files, build/tool config and raw data files.
<FilesMatch "\.(env|log|sql|bak|sh|htpasswd|json|lock|xml|neon|dist|txt)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Allow public-facing manifests and service worker that intentionally live in the root
<FilesMatch "^(manifest\.json|sw\.js)$">
    Order allow,deny
    Allow from all
</FilesMatch>

# Prevent direct access to configuration, source code, and backup directories
<IfModule mod_authz_core.c>
    <DirectoryMatch "^.*(logs|backups|private|config|bootstrap|src|cron|auth|vendor)$">
        Require all denied
    </DirectoryMatch>
</IfModule>

# Block direct PHP execution in legacy and internal directories
# All requests must go through the front-controller (index.php)
<FilesMatch "\.php$">
    <IfModule mod_authz_core.c>
        <If "%{REQUEST_URI} =~ m#^(/[^/]+)?/(auth|pages|bootstrap|src|cron)/#">
            Require all denied
        </If>
    </IfModule>
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Enforce HTTPS – redirect all plain-HTTP requests to HTTPS.
    # Uncomment the next two lines if HTTPS termination is done on this server
    # (not already handled by a load balancer / reverse proxy sending X-Forwarded-Proto).
    # RewriteCond %{HTTPS} off
    # RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # When behind a reverse proxy, redirect HTTP → HTTPS using the forwarded proto header.
    RewriteCond %{HTTP:X-Forwarded-Proto} =http
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Block direct access to PHP scripts in auth/, pages/, bootstrap/, src/, cron/
    # All requests must go through the front-controller so that
    # authentication, CSRF protection and middleware are enforced uniformly.
    RewriteCond %{REQUEST_URI} ^(/[^/]+)?/(auth|pages|bootstrap|src|cron)/.*\.php
    RewriteRule ^ - [F,L]

    # Allow direct access to real files and directories
    # (assets, vendor, uploads remain directly accessible)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Route all other requests through the front-controller (index.php)
    RewriteRule ^ index.php [L]
</IfModule>
