Options -Indexes

# -----------------------------------------------------------------------
# Security: block sensitive files and directories
# -----------------------------------------------------------------------
<FilesMatch "\.(env|log|lock|neon|dist|phar|pem|key|crt|sql|sh|bak)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Block direct access to sensitive directories
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block access to hidden directories (e.g. .git, .github)
    RewriteRule ^\.                  - [F,L]

    # Block direct access to config, logs, sql, backups, private
    RewriteRule ^(config|logs|sql|backups|private)/  - [F,L]

    # -----------------------------------------------------------------------
    # Front-Controller: forward all requests without an existing file/directory
    # to index.php.  This enables clean URLs (/login, /dashboard, etc.) while
    # still allowing direct .php access (pages/, api/) to continue working.
    # -----------------------------------------------------------------------
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>

# -----------------------------------------------------------------------
# HTTPS redirect (uncomment on production)
# -----------------------------------------------------------------------
# <IfModule mod_rewrite.c>
#     RewriteCond %{HTTPS} off
#     RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
# </IfModule>

# -----------------------------------------------------------------------
# Performance: browser caching for static assets
# -----------------------------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css                  "access plus 1 year"
    ExpiresByType application/javascript    "access plus 1 year"
    ExpiresByType image/webp                "access plus 1 year"
    ExpiresByType image/png                 "access plus 1 year"
    ExpiresByType image/jpeg                "access plus 1 year"
    ExpiresByType image/svg+xml             "access plus 1 year"
    ExpiresByType font/woff2                "access plus 1 year"
</IfModule>

# -----------------------------------------------------------------------
# Compression
# -----------------------------------------------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>
