Options -Indexes

# Security: Deny access to sensitive directories and files
<FilesMatch "\.(env|log|sql|bak|sh|htpasswd)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Prevent direct access to configuration, source code, and backup directories
<IfModule mod_authz_core.c>
    <DirectoryMatch "^.*(logs|backups|private|config|bootstrap|src|cron|includes|vendor)$">
        Require all denied
    </DirectoryMatch>
</IfModule>

# Block direct PHP execution in legacy and internal directories
# All requests must go through the front-controller (index.php)
<FilesMatch "\.php$">
    <IfModule mod_authz_core.c>
        <If "%{REQUEST_URI} =~ m#^(/[^/]+)?/(api|pages|includes|bootstrap|src|cron)/#">
            Require all denied
        </If>
    </IfModule>
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Preserve HTTPS (handled at web server level, but keep header hint)
    RewriteCond %{HTTP:X-Forwarded-Proto} !https
    RewriteCond %{HTTPS} off
    # Uncomment the next two lines in production to force HTTPS
    # RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Block direct access to PHP scripts in api/, pages/, includes/, bootstrap/, src/, cron/
    # All requests must go through the front-controller so that
    # authentication, CSRF protection and middleware are enforced uniformly.
    RewriteCond %{REQUEST_URI} ^(/[^/]+)?/(api|pages|includes|bootstrap|src|cron)/.*\.php
    RewriteRule ^ - [F,L]

    # Allow direct access to real files and directories
    # (assets, vendor, uploads remain directly accessible)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Route all other requests through the front-controller (index.php)
    RewriteRule ^ index.php [L]
</IfModule>
