Options -Indexes

# Security: Deny access to sensitive directories and files
<FilesMatch "\.(env|log|sql|bak|sh|htpasswd)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Prevent direct access to configuration and backup directories
<IfModule mod_authz_core.c>
    <DirectoryMatch "^.*(logs|backups|private|config)$">
        Require all denied
    </DirectoryMatch>
</IfModule>

# Block direct access to legacy api/ scripts (except api/public/).
# All API requests must go through the front-controller (index.php) so that
# authentication, CSRF protection, and middleware are enforced uniformly.
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{REQUEST_URI} ^/api/(?!public/)
    RewriteCond %{REQUEST_FILENAME} \.php$
    RewriteRule ^ index.php [L]
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Preserve HTTPS (handled at web server level, but keep header hint)
    RewriteCond %{HTTP:X-Forwarded-Proto} !https
    RewriteCond %{HTTPS} off
    # Uncomment the next two lines in production to force HTTPS
    # RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Allow direct access to real files and directories
    # Note: api/*.php files are intentionally excluded from direct access above.
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Route all other requests through the front-controller (index.php)
    RewriteRule ^ index.php [L]
</IfModule>
