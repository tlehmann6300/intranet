#!/usr/bin/env bash
# ===========================================================================
# IBC Intranet – Recommended Crontab Configuration
# ===========================================================================
#
# Add these entries to the system crontab or the web server user's crontab:
#   crontab -e
#
# Replace /var/www/intranet with the actual installation path.
# The PHP binary path may differ; use `which php` to find it.
#
# All commands log to stdout/stderr. Use >> /path/to/logs/cron.log 2>&1
# to capture output if your system does not log cron output automatically.
# ===========================================================================

# ── Every 5 minutes ─────────────────────────────────────────────────────────
# Update event statuses (planned → closed → completed) based on start/end times.
# Replaces the pseudo-cron in includes/pseudo_cron.php.
*/5 * * * * php /var/www/intranet/bin/console app:update-event-statuses >> /var/www/intranet/logs/cron.log 2>&1

# ── Every 5 minutes ─────────────────────────────────────────────────────────
# Process the outgoing mail queue stored in the database.
*/5 * * * * php /var/www/intranet/bin/console app:process-mail-queue >> /var/www/intranet/logs/cron.log 2>&1

# ── Every 30 minutes ────────────────────────────────────────────────────────
# Sync inventory objects from EasyVerein API.
*/30 * * * * php /var/www/intranet/bin/console app:sync-easyverein >> /var/www/intranet/logs/cron.log 2>&1

# ── Daily at 08:00 ──────────────────────────────────────────────────────────
# Send birthday greeting e-mails to users celebrating today.
0 8 * * * php /var/www/intranet/bin/console app:send-birthday-wishes >> /var/www/intranet/logs/cron.log 2>&1

# ── Daily at 02:00 ──────────────────────────────────────────────────────────
# Create gzip SQL dumps of all six databases (stored in /backups/).
0 2 * * * php /var/www/intranet/bin/console app:backup-database >> /var/www/intranet/logs/cron.log 2>&1

# ── Every Monday at 09:00 ───────────────────────────────────────────────────
# Remind users with incomplete profiles to complete them.
0 9 * * 1 php /var/www/intranet/bin/console app:send-profile-reminders >> /var/www/intranet/logs/cron.log 2>&1

# ── 1st of every month at 09:00 ─────────────────────────────────────────────
# Send periodic reminder e-mails to alumni.
0 9 1 * * php /var/www/intranet/bin/console app:send-alumni-reminders >> /var/www/intranet/logs/cron.log 2>&1

# ── Every weekday at 18:00 ──────────────────────────────────────────────────
# Reconcile bank payments with outstanding invoices.
0 18 * * 1-5 php /var/www/intranet/bin/console app:reconcile-bank-payments >> /var/www/intranet/logs/cron.log 2>&1
