{#
 * templates/auth/login.html.twig
 *
 * Login page – powered by the front-controller route  GET /login
 * (AuthController::showLogin) and POST /login (AuthController::handleLogin).
 *
 * Variables injected by AuthController:
 *   csrf_token  string   CSRF token
 *   flash       array|null {type: string, message: string}
 *   error       string|null  OAuth error passed as query parameter
 #}
{% extends '_base.html.twig' %}

{% block title %}IBC Intranet – Login{% endblock %}

{% block head_extra %}
<style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background: #0a0f1e;
        min-height: 100vh;
        min-height: 100dvh;
        display: flex;
        justify-content: center;
        align-items: center;
        overflow-x: hidden;
        overflow-y: auto;
        position: relative;
    }

    .background-wrapper {
        position: fixed; top: 0; left: 0;
        width: 100%; height: 100%;
        z-index: 1; overflow: hidden;
    }

    .gradient-bg {
        position: absolute;
        width: 200%; height: 200%;
        top: -50%; left: -50%;
        background:
            radial-gradient(circle at 20% 50%, rgba(108,183,62,.2) 0%, transparent 50%),
            radial-gradient(circle at 80% 80%, rgba(30,76,156,.2)  0%, transparent 50%),
            radial-gradient(circle at 40% 20%, rgba(118,75,162,.15) 0%, transparent 50%),
            linear-gradient(135deg, #0a0f1e 0%, #1a1f3e 100%);
        animation: gradientShift 25s ease-in-out infinite;
    }

    @keyframes gradientShift {
        0%,100% { transform: translate(0,0) scale(1); }
        25%     { transform: translate(-3%,3%) scale(1.05); }
        50%     { transform: translate(0,5%) scale(1.1); }
        75%     { transform: translate(3%,3%) scale(1.05); }
    }

    .login-container {
        position: relative; z-index: 10;
        width: 100%; max-width: 420px;
        padding: 16px;
    }

    .login-card {
        background: rgba(255,255,255,.05);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,.1);
        border-radius: 24px;
        padding: 40px 36px;
        box-shadow: 0 25px 50px rgba(0,0,0,.5);
    }

    .login-card h1 {
        color: #f8fafc; font-size: 1.75rem; font-weight: 700;
        margin-bottom: 6px;
    }

    .login-card .subtitle {
        color: rgba(248,250,252,.6); font-size: .9rem; margin-bottom: 32px;
    }

    .form-label {
        color: rgba(248,250,252,.8); font-size: .85rem;
        font-weight: 500; margin-bottom: 6px; display: block;
    }

    .form-control {
        background: rgba(255,255,255,.08);
        border: 1px solid rgba(255,255,255,.12);
        border-radius: 12px;
        color: #f8fafc; padding: 12px 16px;
        font-size: .95rem; width: 100%;
        transition: border-color .2s, box-shadow .2s;
    }

    .form-control:focus {
        outline: none;
        border-color: rgba(108,183,62,.6);
        box-shadow: 0 0 0 3px rgba(108,183,62,.15);
        background: rgba(255,255,255,.1);
    }

    .form-control::placeholder { color: rgba(248,250,252,.3); }

    .btn-login {
        width: 100%;
        background: linear-gradient(135deg, #6cb73e, #5aa032);
        border: none; border-radius: 12px;
        color: #fff; font-size: 1rem; font-weight: 600;
        padding: 14px;
        cursor: pointer;
        transition: opacity .2s, transform .1s;
        margin-top: 8px;
    }

    .btn-login:hover  { opacity: .9; }
    .btn-login:active { transform: scale(.98); }

    .alert-error {
        background: rgba(239,68,68,.15);
        border: 1px solid rgba(239,68,68,.3);
        border-radius: 12px;
        color: #fca5a5; padding: 12px 16px;
        margin-bottom: 20px; font-size: .9rem;
    }

    .alert-success {
        background: rgba(34,197,94,.15);
        border: 1px solid rgba(34,197,94,.3);
        border-radius: 12px;
        color: #86efac; padding: 12px 16px;
        margin-bottom: 20px; font-size: .9rem;
    }

    .divider {
        display: flex; align-items: center;
        gap: 12px; margin: 24px 0;
        color: rgba(248,250,252,.3); font-size: .85rem;
    }

    .divider::before, .divider::after {
        content: ''; flex: 1;
        height: 1px; background: rgba(255,255,255,.1);
    }

    .btn-microsoft {
        width: 100%;
        background: rgba(255,255,255,.08);
        border: 1px solid rgba(255,255,255,.12);
        border-radius: 12px;
        color: #f8fafc; font-size: .95rem; font-weight: 500;
        padding: 12px; cursor: pointer;
        transition: background .2s;
        display: flex; align-items: center; justify-content: center; gap: 10px;
        text-decoration: none;
    }

    .btn-microsoft:hover { background: rgba(255,255,255,.12); color: #f8fafc; }
</style>
{% endblock %}

{% block body %}
<div class="background-wrapper">
    <div class="gradient-bg"></div>
</div>

<div class="login-container">
    <div class="login-card">

        <h1>Willkommen zurück</h1>
        <p class="subtitle">Melde dich mit deinen Zugangsdaten an</p>

        {# Flash messages #}
        {% if flash %}
            <div class="alert-{{ flash.type == 'error' ? 'error' : 'success' }}">
                {{ flash.message }}
            </div>
        {% endif %}

        {# OAuth error #}
        {% if error %}
            <div class="alert-error">{{ error }}</div>
        {% endif %}

        {# Login form #}
        <form method="POST" action="{{ base_url }}/login" autocomplete="on">
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

            <div style="margin-bottom: 16px;">
                <label class="form-label" for="email">E-Mail-Adresse</label>
                <input class="form-control" type="email" id="email" name="email"
                       placeholder="deine@email.de" required autocomplete="email">
            </div>

            <div style="margin-bottom: 24px;">
                <label class="form-label" for="password">Passwort</label>
                <input class="form-control" type="password" id="password" name="password"
                       placeholder="••••••••" required autocomplete="current-password">
            </div>

            <button type="submit" class="btn-login">Anmelden</button>
        </form>

        <div class="divider">oder</div>

        {# Microsoft SSO #}
        <a href="{{ base_url }}/pages/auth/login.php?sso=microsoft" class="btn-microsoft">
            <svg width="20" height="20" viewBox="0 0 21 21" xmlns="http://www.w3.org/2000/svg">
                <rect x="1"  y="1"  width="9" height="9" fill="#f25022"/>
                <rect x="11" y="1"  width="9" height="9" fill="#7fba00"/>
                <rect x="1"  y="11" width="9" height="9" fill="#00a4ef"/>
                <rect x="11" y="11" width="9" height="9" fill="#ffb900"/>
            </svg>
            Mit Microsoft anmelden
        </a>

    </div>
</div>
{% endblock %}
