{% extends 'layouts/main.twig' %}
{% block title %}Kategorien verwalten – IBC Intranet{% endblock %}
{% block content %}
<div class="max-w-4xl mx-auto py-4">
    <div class="mb-8">
        <a href="{{ base_url }}/admin" class="text-sm text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200">
            ← Zurück zur Admin-Übersicht
        </a>
        <h1 class="text-2xl font-bold text-gray-800 dark:text-gray-100 mt-2">Kategorien verwalten</h1>
    </div>

    {% if message %}<div class="mb-4 p-4 bg-green-100 dark:bg-green-900 border border-green-400 text-green-700 dark:text-green-300 rounded-lg">{{ message }}</div>{% endif %}
    {% if error %}<div class="mb-4 p-4 bg-red-100 dark:bg-red-900 border border-red-400 text-red-700 dark:text-red-300 rounded-lg">{{ error }}</div>{% endif %}

    <div class="bg-white dark:bg-gray-900 rounded-2xl border border-gray-100 dark:border-gray-800 shadow-sm p-6 mb-8">
        <h2 class="text-lg font-semibold text-gray-800 dark:text-gray-100 mb-4">Neue Kategorie erstellen</h2>
        <form method="POST" class="space-y-4">
            <input type="hidden" name="csrf_token" value="{{ csrfToken }}">
            <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Name *</label>
                <input type="text" name="name" required class="w-full px-4 py-2.5 border border-gray-300 dark:border-gray-600 rounded-xl dark:bg-gray-800 dark:text-gray-100">
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Beschreibung</label>
                <input type="text" name="description" class="w-full px-4 py-2.5 border border-gray-300 dark:border-gray-600 rounded-xl dark:bg-gray-800 dark:text-gray-100">
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Farbe</label>
                <input type="color" name="color" value="#3B82F6" class="h-10 w-20 border border-gray-300 dark:border-gray-600 rounded-xl cursor-pointer">
            </div>
            <button type="submit" name="create_category" value="1" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition">
                Kategorie erstellen
            </button>
        </form>
    </div>

    {% if categories %}
    <div class="bg-white dark:bg-gray-900 rounded-2xl border border-gray-100 dark:border-gray-800 shadow-sm overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-gray-50 dark:bg-gray-800">
                <tr>
                    <th class="px-4 py-3 text-left text-gray-700 dark:text-gray-300">Name</th>
                    <th class="px-4 py-3 text-left text-gray-700 dark:text-gray-300">Farbe</th>
                    <th class="px-4 py-3 text-left text-gray-700 dark:text-gray-300">Beschreibung</th>
                    <th class="px-4 py-3"></th>
                </tr>
            </thead>
            <tbody>
                {% for cat in categories %}
                <tr class="border-t border-gray-100 dark:border-gray-800">
                    <td class="px-4 py-3 text-gray-900 dark:text-gray-100">{{ cat.name }}</td>
                    <td class="px-4 py-3">
                        <span class="inline-block w-5 h-5 rounded" style="background-color: {{ cat.color|default('#3B82F6') }}"></span>
                    </td>
                    <td class="px-4 py-3 text-gray-600 dark:text-gray-400">{{ cat.description }}</td>
                    <td class="px-4 py-3">
                        <form method="POST" onsubmit="return confirm('Kategorie wirklich löschen?');">
                            <input type="hidden" name="csrf_token" value="{{ csrfToken }}">
                            <input type="hidden" name="category_id" value="{{ cat.id }}">
                            <button type="submit" name="delete_category" value="1" class="text-red-600 hover:text-red-800 text-sm">Löschen</button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <p class="text-gray-500 dark:text-gray-400">Keine Kategorien vorhanden.</p>
    {% endif %}
</div>
{% endblock %}
