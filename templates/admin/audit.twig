{% extends 'layouts/main.twig' %}
{% block title %}Audit-Logs – IBC Intranet{% endblock %}

{% block content %}
<div class="max-w-7xl mx-auto">

{# ── Page header ─────────────────────────────────────────────────────────── #}
<div class="mb-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
        <div class="flex items-center gap-3 mb-1">
            <div class="w-11 h-11 rounded-2xl bg-purple-100 dark:bg-purple-900/40 flex items-center justify-center shadow-sm">
                <i class="fas fa-clipboard-list text-purple-600 dark:text-purple-400 text-xl"></i>
            </div>
            <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-gray-50 tracking-tight">Audit-Logs</h1>
        </div>
        <p class="text-gray-500 dark:text-gray-400 text-sm ml-14">{{ totalLogs|number_format(0, ',', '.') }} Einträge insgesamt</p>
    </div>
    <div class="flex gap-2 flex-wrap">
        <a href="?{{ filterAction ? 'action=' ~ filterAction|url_encode ~ '&' : '' }}{{ filterUserId ? 'user_id=' ~ filterUserId ~ '&' : '' }}{{ filterDate ? 'date=' ~ filterDate ~ '&' : '' }}export=csv"
           class="inline-flex items-center gap-2 px-4 py-2 bg-green-600 hover:bg-green-700 text-white rounded-lg text-sm font-medium transition">
            <i class="fas fa-file-csv"></i> CSV Export
        </a>
        <a href="?{{ filterAction ? 'action=' ~ filterAction|url_encode ~ '&' : '' }}{{ filterUserId ? 'user_id=' ~ filterUserId ~ '&' : '' }}{{ filterDate ? 'date=' ~ filterDate ~ '&' : '' }}verify_chain=1"
           class="inline-flex items-center gap-2 px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg text-sm font-medium transition"
           title="Prüft die SHA-256 Hash-Kette auf Manipulationen">
            <i class="fas fa-shield-alt"></i> Integrität prüfen
        </a>
    </div>
</div>

{# ── Chain integrity result ───────────────────────────────────────────────── #}
{% if chainStatus is not null %}
<div class="mb-6 rounded-xl p-4 {{ chainStatus.valid ? 'bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-700' : 'bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-700' }}">
    <div class="flex items-center gap-3">
        <i class="fas {{ chainStatus.valid ? 'fa-check-circle text-green-600 dark:text-green-400' : 'fa-exclamation-triangle text-red-600 dark:text-red-400' }} text-xl"></i>
        <div>
            {% if chainStatus.valid %}
            <p class="font-semibold text-green-800 dark:text-green-200">Hash-Kette intakt</p>
            <p class="text-sm text-green-700 dark:text-green-300">Alle {{ chainStatus.total }} Einträge sind unverändert (SHA-256 Kette verifiziert).</p>
            {% else %}
            <p class="font-semibold text-red-800 dark:text-red-200">⚠ Hash-Kette gebrochen!</p>
            <p class="text-sm text-red-700 dark:text-red-300">
                Manipulierung erkannt ab Eintrag ID {{ chainStatus.broken_at ?? '?' }}.
                Dies deutet auf nachträgliche Änderungen hin. Bitte sofort prüfen!
            </p>
            {% endif %}
        </div>
    </div>
</div>
{% endif %}

{# ── Filters ─────────────────────────────────────────────────────────────── #}
<div class="card p-5 mb-6 rounded-xl shadow-sm">
    <form method="GET" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 md:gap-4">
        <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Aktion</label>
            <input type="text" name="action" placeholder="z.B. login, role_change…"
                   value="{{ filterAction }}"
                   class="w-full px-3 py-2 bg-white border border-gray-300 text-gray-900 rounded-lg focus:ring-2 focus:ring-purple-400/50 focus:border-purple-400 dark:bg-gray-800 dark:border-gray-600 dark:text-white text-sm transition-colors">
        </div>
        <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Benutzer-ID</label>
            <input type="number" name="user_id" placeholder="Benutzer-ID"
                   value="{{ filterUserId }}"
                   class="w-full px-3 py-2 bg-white border border-gray-300 text-gray-900 rounded-lg focus:ring-2 focus:ring-purple-400/50 focus:border-purple-400 dark:bg-gray-800 dark:border-gray-600 dark:text-white text-sm transition-colors">
        </div>
        <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Datum</label>
            <input type="date" name="date" value="{{ filterDate }}"
                   class="w-full px-3 py-2 bg-white border border-gray-300 text-gray-900 rounded-lg focus:ring-2 focus:ring-purple-400/50 focus:border-purple-400 dark:bg-gray-800 dark:border-gray-600 dark:text-white text-sm transition-colors">
        </div>
        <div class="flex items-end gap-2">
            <button type="submit" class="flex-1 bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition min-h-[40px]">
                <i class="fas fa-search mr-1"></i> Filtern
            </button>
            <a href="/admin/audit" class="px-3 py-2 min-h-[40px] flex items-center justify-center bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-600 transition" title="Filter zurücksetzen">
                <i class="fas fa-times text-sm"></i>
            </a>
        </div>
    </form>
</div>

{# ── Log timeline ─────────────────────────────────────────────────────────── #}
<div class="card rounded-xl shadow-sm overflow-hidden">
    {% if logs is empty %}
    <div class="p-16 text-center">
        <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-gray-100 dark:bg-gray-700 flex items-center justify-center">
            <i class="fas fa-clipboard text-3xl text-gray-300 dark:text-gray-500"></i>
        </div>
        <p class="text-gray-500 dark:text-gray-400 text-lg font-medium">Keine Logs gefunden</p>
        <p class="text-gray-400 dark:text-gray-500 text-sm mt-1">Versuche andere Filterkriterien</p>
    </div>
    {% else %}

    {# Legend #}
    <div class="px-6 pt-5 pb-3 border-b border-gray-100 dark:border-gray-700 flex flex-wrap gap-3">
        <span class="inline-flex items-center gap-1.5 text-xs text-gray-500 dark:text-gray-400"><span class="w-2 h-2 rounded-full bg-green-500"></span>Erstellt / Login</span>
        <span class="inline-flex items-center gap-1.5 text-xs text-gray-500 dark:text-gray-400"><span class="w-2 h-2 rounded-full bg-amber-400"></span>Aktualisiert</span>
        <span class="inline-flex items-center gap-1.5 text-xs text-gray-500 dark:text-gray-400"><span class="w-2 h-2 rounded-full bg-red-500"></span>Gelöscht / Fehlgeschlagen</span>
        <span class="inline-flex items-center gap-1.5 text-xs text-gray-500 dark:text-gray-400"><span class="w-2 h-2 rounded-full bg-purple-500"></span>Einladung / Rolle</span>
        <span class="inline-flex items-center gap-1.5 text-xs text-gray-500 dark:text-gray-400"><span class="w-2 h-2 rounded-full bg-gray-400"></span>Sonstige</span>
    </div>

    <div class="divide-y divide-gray-50 dark:divide-gray-700/50">
        {% for log in logs %}
        {% set action = log.action|lower %}
        {% if 'delete' in action %}
            {% set badgeClass = 'bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-300' %}
            {% set icon = 'fas fa-trash-alt' %}
            {% set dot = 'bg-red-500' %}
        {% elseif 'login_fail' in action or 'failed' in action or 'locked' in action %}
            {% set badgeClass = 'bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-300' %}
            {% set icon = 'fas fa-times-circle' %}
            {% set dot = 'bg-red-400' %}
        {% elseif 'create' in action or 'login_success' in action %}
            {% set badgeClass = 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300' %}
            {% set icon = 'fas fa-plus-circle' %}
            {% set dot = 'bg-green-500' %}
        {% elseif 'login' in action %}
            {% set badgeClass = 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300' %}
            {% set icon = 'fas fa-sign-in-alt' %}
            {% set dot = 'bg-green-400' %}
        {% elseif 'logout' in action %}
            {% set badgeClass = 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300' %}
            {% set icon = 'fas fa-sign-out-alt' %}
            {% set dot = 'bg-gray-400' %}
        {% elseif 'update' in action or 'change' in action %}
            {% set badgeClass = 'bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-300' %}
            {% set icon = 'fas fa-pencil-alt' %}
            {% set dot = 'bg-amber-400' %}
        {% elseif 'invitation' in action or 'role' in action %}
            {% set badgeClass = 'bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-300' %}
            {% set icon = 'fas fa-user-shield' %}
            {% set dot = 'bg-purple-500' %}
        {% else %}
            {% set badgeClass = 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300' %}
            {% set icon = 'fas fa-circle' %}
            {% set dot = 'bg-gray-400' %}
        {% endif %}

        <div class="flex items-start gap-4 px-6 py-4 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
            <div class="flex-shrink-0 mt-0.5">
                <div class="w-8 h-8 rounded-full {{ badgeClass }} flex items-center justify-center">
                    <i class="{{ icon }} text-xs"></i>
                </div>
            </div>
            <div class="flex-1 min-w-0">
                <div class="flex flex-wrap items-center gap-2 mb-1">
                    <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-semibold max-w-full break-all {{ badgeClass }}">
                        <span class="w-1.5 h-1.5 rounded-full {{ dot }} flex-shrink-0"></span>
                        {{ log.action }}
                    </span>
                    {% if log.entity_type %}
                    <span class="text-xs text-gray-500 dark:text-gray-400">
                        {{ log.entity_type }}{% if log.entity_id %} <span class="text-gray-400 dark:text-gray-500">#{{ log.entity_id }}</span>{% endif %}
                    </span>
                    {% endif %}
                </div>
                {% if log.details and log.details != '-' %}
                <p class="text-sm text-gray-600 dark:text-gray-300 break-all">{{ log.details }}</p>
                {% endif %}
                <div class="flex flex-wrap items-center gap-3 mt-1.5 text-xs text-gray-400 dark:text-gray-500">
                    <span class="inline-flex items-center gap-1">
                        <i class="fas fa-clock"></i>
                        {{ log.timestamp|date('d.m.Y H:i:s') }}
                    </span>
                    {% if log.user_id %}
                    <span class="inline-flex items-center gap-1"><i class="fas fa-user"></i> ID: {{ log.user_id }}</span>
                    {% else %}
                    <span class="inline-flex items-center gap-1 italic"><i class="fas fa-robot"></i> System</span>
                    {% endif %}
                    {% if log.ip_address %}
                    <span class="inline-flex items-center gap-1"><i class="fas fa-network-wired"></i> {{ log.ip_address }}</span>
                    {% endif %}
                </div>
            </div>
        </div>
        {% endfor %}
    </div>

    {# Pagination #}
    {% if totalPages > 1 %}
    <div class="px-6 py-4 bg-gray-50 dark:bg-gray-800/50 border-t border-gray-100 dark:border-gray-700 flex items-center justify-between">
        <div class="text-sm text-gray-500 dark:text-gray-400">Seite {{ page }} von {{ totalPages }}</div>
        <div class="flex gap-3">
            {% if page > 1 %}
            <a href="?page={{ page - 1 }}{{ filterAction ? '&action=' ~ filterAction|url_encode : '' }}{{ filterUserId ? '&user_id=' ~ filterUserId : '' }}{{ filterDate ? '&date=' ~ filterDate : '' }}"
               class="inline-flex items-center gap-1 px-4 py-2 bg-white dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-600 transition text-sm text-gray-700 dark:text-gray-300">
                <i class="fas fa-chevron-left text-xs"></i> Zurück
            </a>
            {% endif %}
            {% if page < totalPages %}
            <a href="?page={{ page + 1 }}{{ filterAction ? '&action=' ~ filterAction|url_encode : '' }}{{ filterUserId ? '&user_id=' ~ filterUserId : '' }}{{ filterDate ? '&date=' ~ filterDate : '' }}"
               class="inline-flex items-center gap-1 px-4 py-2 bg-white dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-600 transition text-sm text-gray-700 dark:text-gray-300">
                Weiter <i class="fas fa-chevron-right text-xs"></i>
            </a>
            {% endif %}
        </div>
    </div>
    {% endif %}

    {% endif %}
</div>

</div>
{% endblock %}

