{% extends 'layouts/main.twig' %}
{% block title %}Inventar-Verwaltung – IBC Intranet{% endblock %}
{% block content %}
<div class="max-w-6xl mx-auto py-4">
    <div class="mb-8">
        <a href="{{ base_url }}/admin" class="text-sm text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200">
            ← Zurück zur Admin-Übersicht
        </a>
        <h1 class="text-2xl font-bold text-gray-800 dark:text-gray-100 mt-2">Inventar-Verwaltung</h1>
    </div>

    <div class="flex gap-4 mb-6">
        <a href="?filter=all" class="px-4 py-2 rounded-lg text-sm font-medium transition
            {{ filter == 'all' ? 'bg-blue-600 text-white' : 'bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800' }}">
            Alle Artikel
        </a>
        <a href="?filter=rented" class="px-4 py-2 rounded-lg text-sm font-medium transition
            {{ filter == 'rented' ? 'bg-blue-600 text-white' : 'bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800' }}">
            Aktive Ausleihen
        </a>
        <a href="?export=csv" class="ml-auto px-4 py-2 rounded-lg text-sm font-medium bg-green-600 text-white hover:bg-green-700 transition">
            CSV exportieren
        </a>
    </div>

    {% if pendingRequests %}
    <div class="bg-white dark:bg-gray-900 rounded-2xl border border-gray-100 dark:border-gray-800 shadow-sm overflow-hidden mb-8">
        <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800">
            <h2 class="text-lg font-semibold text-gray-800 dark:text-gray-100">Offene Anfragen ({{ pendingRequests|length }})</h2>
        </div>
        <table class="w-full text-sm">
            <thead class="bg-gray-50 dark:bg-gray-800">
                <tr>
                    <th class="px-4 py-3 text-left text-gray-700 dark:text-gray-300">Artikel</th>
                    <th class="px-4 py-3 text-left text-gray-700 dark:text-gray-300">Benutzer</th>
                    <th class="px-4 py-3 text-left text-gray-700 dark:text-gray-300">Zeitraum</th>
                    <th class="px-4 py-3 text-left text-gray-700 dark:text-gray-300">Menge</th>
                    <th class="px-4 py-3 text-left text-gray-700 dark:text-gray-300">Status</th>
                </tr>
            </thead>
            <tbody>
                {% for req in pendingRequests %}
                <tr class="border-t border-gray-100 dark:border-gray-800">
                    <td class="px-4 py-3 text-gray-900 dark:text-gray-100">{{ req.item_name ?? req.inventory_id }}</td>
                    <td class="px-4 py-3 text-gray-600 dark:text-gray-400">{{ req.user_email ?? req.user_id }}</td>
                    <td class="px-4 py-3 text-gray-600 dark:text-gray-400">
                        {{ req.start_date ? req.start_date|date('d.m.Y') : '–' }}
                        {% if req.end_date %} – {{ req.end_date|date('d.m.Y') }}{% endif %}
                    </td>
                    <td class="px-4 py-3 text-gray-600 dark:text-gray-400">{{ req.quantity }}</td>
                    <td class="px-4 py-3">
                        <span class="inline-block px-2 py-1 text-xs font-medium rounded-full bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200">
                            {{ req.status }}
                        </span>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% endif %}

    {% if filter == 'rented' %}
        {% if activeRentals %}
        <div class="bg-white dark:bg-gray-900 rounded-2xl border border-gray-100 dark:border-gray-800 shadow-sm overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800">
                <h2 class="text-lg font-semibold text-gray-800 dark:text-gray-100">Aktive Ausleihen ({{ activeRentals|length }})</h2>
            </div>
            <table class="w-full text-sm">
                <thead class="bg-gray-50 dark:bg-gray-800">
                    <tr>
                        <th class="px-4 py-3 text-left text-gray-700 dark:text-gray-300">Artikel</th>
                        <th class="px-4 py-3 text-left text-gray-700 dark:text-gray-300">Benutzer</th>
                        <th class="px-4 py-3 text-left text-gray-700 dark:text-gray-300">Seit</th>
                        <th class="px-4 py-3 text-left text-gray-700 dark:text-gray-300">Fällig</th>
                    </tr>
                </thead>
                <tbody>
                    {% for rental in activeRentals %}
                    <tr class="border-t border-gray-100 dark:border-gray-800">
                        <td class="px-4 py-3 text-gray-900 dark:text-gray-100">{{ rental.item_name ?? rental.inventory_id }}</td>
                        <td class="px-4 py-3 text-gray-600 dark:text-gray-400">{{ rental.user_email ?? rental.user_id }}</td>
                        <td class="px-4 py-3 text-gray-600 dark:text-gray-400">{{ rental.rental_date ? rental.rental_date|date('d.m.Y') : '–' }}</td>
                        <td class="px-4 py-3 text-gray-600 dark:text-gray-400">{{ rental.return_date ? rental.return_date|date('d.m.Y') : '–' }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% else %}
        <p class="text-gray-500 dark:text-gray-400">Keine aktiven Ausleihen vorhanden.</p>
        {% endif %}
    {% else %}
        {% if allItems %}
        <div class="bg-white dark:bg-gray-900 rounded-2xl border border-gray-100 dark:border-gray-800 shadow-sm overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800">
                <h2 class="text-lg font-semibold text-gray-800 dark:text-gray-100">Alle Artikel ({{ allItems|length }})</h2>
            </div>
            <table class="w-full text-sm">
                <thead class="bg-gray-50 dark:bg-gray-800">
                    <tr>
                        <th class="px-4 py-3 text-left text-gray-700 dark:text-gray-300">Artikel</th>
                        <th class="px-4 py-3 text-left text-gray-700 dark:text-gray-300">Kategorie</th>
                        <th class="px-4 py-3 text-right text-gray-700 dark:text-gray-300">Gesamt</th>
                        <th class="px-4 py-3 text-right text-gray-700 dark:text-gray-300">Verfügbar</th>
                        <th class="px-4 py-3 text-left text-gray-700 dark:text-gray-300">Einheit</th>
                        <th class="px-4 py-3"></th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in allItems %}
                    <tr class="border-t border-gray-100 dark:border-gray-800">
                        <td class="px-4 py-3 text-gray-900 dark:text-gray-100">
                            <a href="{{ base_url }}/inventory/{{ item.id }}" class="hover:text-blue-600 dark:hover:text-blue-400">{{ item.name }}</a>
                        </td>
                        <td class="px-4 py-3 text-gray-600 dark:text-gray-400">{{ item.category_name ?? '–' }}</td>
                        <td class="px-4 py-3 text-right text-gray-900 dark:text-gray-100">{{ item.quantity }}</td>
                        <td class="px-4 py-3 text-right">
                            <span class="font-medium {{ item.available_quantity > 0 ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400' }}">
                                {{ item.available_quantity }}
                            </span>
                        </td>
                        <td class="px-4 py-3 text-gray-600 dark:text-gray-400">{{ item.unit }}</td>
                        <td class="px-4 py-3">
                            <a href="{{ base_url }}/inventory/{{ item.id }}/edit" class="text-blue-600 hover:text-blue-800 dark:text-blue-400 text-xs">Bearbeiten</a>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% else %}
        <p class="text-gray-500 dark:text-gray-400">Keine Artikel vorhanden.</p>
        {% endif %}
    {% endif %}
</div>
{% endblock %}
