{% extends 'layouts/main.twig' %}
{% block title %}Aktive Ausleihen – IBC Intranet{% endblock %}
{% block content %}
<div class="max-w-6xl mx-auto py-4">
    <div class="mb-8">
        <a href="{{ base_url }}/admin" class="text-sm text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200">
            ← Zurück zur Admin-Übersicht
        </a>
        <h1 class="text-2xl font-bold text-gray-800 dark:text-gray-100 mt-2">Aktive Ausleihen</h1>
    </div>

    {% if activeRentals %}
    <div class="bg-white dark:bg-gray-900 rounded-2xl border border-gray-100 dark:border-gray-800 shadow-sm overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-gray-50 dark:bg-gray-800">
                <tr>
                    <th class="px-4 py-3 text-left text-gray-700 dark:text-gray-300">Benutzer</th>
                    <th class="px-4 py-3 text-left text-gray-700 dark:text-gray-300">Artikel</th>
                    <th class="px-4 py-3 text-left text-gray-700 dark:text-gray-300">Ausgeliehen am</th>
                    <th class="px-4 py-3 text-left text-gray-700 dark:text-gray-300">Fällig am</th>
                    <th class="px-4 py-3 text-left text-gray-700 dark:text-gray-300">Status</th>
                </tr>
            </thead>
            <tbody>
                {% for rental in activeRentals %}
                <tr class="border-t border-gray-100 dark:border-gray-800">
                    <td class="px-4 py-3 text-gray-900 dark:text-gray-100">{{ rental.user_email }}</td>
                    <td class="px-4 py-3 text-gray-600 dark:text-gray-400">{{ rental.item_name ?? rental.inventory_id }}</td>
                    <td class="px-4 py-3 text-gray-600 dark:text-gray-400">{{ rental.rental_date|date('d.m.Y') }}</td>
                    <td class="px-4 py-3 text-gray-600 dark:text-gray-400">{{ rental.due_date ? rental.due_date|date('d.m.Y') : '–' }}</td>
                    <td class="px-4 py-3">
                        <span class="inline-block px-2 py-1 text-xs font-medium rounded-full bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200">
                            {{ rental.status }}
                        </span>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <p class="text-gray-500 dark:text-gray-400">Keine aktiven Ausleihen vorhanden.</p>
    {% endif %}
</div>
{% endblock %}
