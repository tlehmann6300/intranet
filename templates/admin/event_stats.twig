{% extends 'layouts/main.twig' %}
{% block title %}Event-Statistiken – IBC Intranet{% endblock %}
{% block content %}
<div class="max-w-6xl mx-auto py-4">
    <div class="mb-4">
        <a href="{{ base_url }}/events" class="text-sm text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200">
            ← Zurück zu Veranstaltungen
        </a>
    </div>

    <h1 class="text-2xl font-bold text-gray-800 dark:text-gray-100 mb-8">Event-Statistiken – Historie</h1>

    {% if allDocs %}
    <div class="bg-white dark:bg-gray-900 rounded-2xl border border-gray-100 dark:border-gray-800 shadow-sm overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-gray-50 dark:bg-gray-800">
                <tr>
                    <th class="px-4 py-3 text-left text-gray-700 dark:text-gray-300">Event</th>
                    <th class="px-4 py-3 text-left text-gray-700 dark:text-gray-300">Datum</th>
                    <th class="px-4 py-3 text-left text-gray-700 dark:text-gray-300">Dokument</th>
                </tr>
            </thead>
            <tbody>
                {% for doc in allDocs %}
                <tr class="border-t border-gray-100 dark:border-gray-800">
                    <td class="px-4 py-3 text-gray-900 dark:text-gray-100">{{ doc.event_title ?? doc.event_id }}</td>
                    <td class="px-4 py-3 text-gray-600 dark:text-gray-400">{{ doc.created_at ? doc.created_at|date('d.m.Y') : '–' }}</td>
                    <td class="px-4 py-3 text-gray-600 dark:text-gray-400">{{ doc.document_type ?? '–' }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <p class="text-gray-500 dark:text-gray-400">Keine Dokumentationen vorhanden.</p>
    {% endif %}
</div>
{% endblock %}
