<!DOCTYPE html>
<html lang="de" class="overflow-x-hidden">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <meta name="color-scheme" content="light dark">
    <meta name="theme-color" content="#0066b3">
    <title>{% block title %}{{ title|default('IBC Intranet') }}{% endblock %}</title>
    <link rel="icon" type="image/webp" href="{{ base_url }}/assets/img/cropped_maskottchen_32x32.webp">
    <link rel="manifest" href="{{ base_url }}/manifest.json">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,300;0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700;0,14..32,800;1,14..32,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="{{ base_url }}/assets/css/theme.css">
    <link rel="stylesheet" href="{{ base_url }}/assets/css/tailwind.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    {% block extra_head %}{% endblock %}
</head>
<body data-user-theme="{{ current_user.theme|default('auto') }}">
    <nav class="sidebar">
        <a href="{{ base_url }}/dashboard" class="sidebar-brand">
            <img src="{{ base_url }}/assets/img/ibc_logo.webp" alt="IBC Logo" style="max-height:40px;">
        </a>
        <ul class="sidebar-nav">
            <li><a href="{{ base_url }}/dashboard" class="{{ base_url ~ '/dashboard' in app.request.pathinfo ? 'active' : '' }}"><i class="fi fi-rr-home"></i> Dashboard</a></li>
            <li><a href="{{ base_url }}/members"><i class="fi fi-rr-users"></i> Mitglieder</a></li>
            <li><a href="{{ base_url }}/events"><i class="fi fi-rr-calendar"></i> Veranstaltungen</a></li>
            <li><a href="{{ base_url }}/blog"><i class="fi fi-rr-document"></i> Blog</a></li>
            <li><a href="{{ base_url }}/projects"><i class="fi fi-rr-briefcase"></i> Projekte</a></li>
            <li><a href="{{ base_url }}/inventory"><i class="fi fi-rr-box"></i> Inventar</a></li>
            <li><a href="{{ base_url }}/invoices"><i class="fi fi-rr-receipt"></i> Rechnungen</a></li>
            <li><a href="{{ base_url }}/alumni"><i class="fi fi-rr-graduation-cap"></i> Alumni</a></li>
            <li><a href="{{ base_url }}/jobs"><i class="fi fi-rr-work-alt"></i> Jobs</a></li>
            <li><a href="{{ base_url }}/newsletter"><i class="fi fi-rr-envelope"></i> Newsletter</a></li>
            <li><a href="{{ base_url }}/polls"><i class="fi fi-rr-vote-yea"></i> Umfragen</a></li>
            <li><a href="{{ base_url }}/links"><i class="fi fi-rr-link"></i> Links</a></li>
            <li><a href="{{ base_url }}/ideas"><i class="fi fi-rr-bulb"></i> Ideen</a></li>
        </ul>
    </nav>

    <main id="main-content" role="main" class="md:ml-64 lg:ml-72 min-h-screen px-4 sm:px-6 lg:px-8 pb-4 pt-16 md:pt-6 lg:pt-8">
        <div class="max-w-7xl mx-auto">
            {% block content %}{% endblock %}
        </div>
        <footer class="max-w-7xl mx-auto mt-8 py-4 border-t border-gray-200 dark:border-slate-700">
            <div class="flex flex-col items-center md:flex-row md:justify-between gap-2 text-sm text-gray-500 dark:text-gray-400">
                <p>&copy; {{ "now"|date("Y") }} IBC Business Consulting. Alle Rechte vorbehalten.</p>
                <a href="{{ base_url }}/impressum">Impressum</a>
            </div>
        </footer>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    {% block extra_scripts %}{% endblock %}
</body>
</html>
