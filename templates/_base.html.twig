{#
 * _base.html.twig
 *
 * Root base template for all pages.
 * Child templates extend this via {% extends '_base.html.twig' %}.
 #}
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <meta name="color-scheme" content="dark">
    <meta name="theme-color" content="#0a0f1e">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <title>{% block title %}IBC Intranet{% endblock %}</title>

    <link rel="icon" type="image/webp" href="{{ base_url }}/assets/img/flaticon.webp">
    <link rel="manifest" href="{{ base_url }}/manifest.json">

    {# DNS prefetch #}
    <link rel="dns-prefetch" href="//fonts.googleapis.com">
    <link rel="dns-prefetch" href="//fonts.gstatic.com">
    <link rel="dns-prefetch" href="//cdn.jsdelivr.net">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,300;0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700;0,14..32,800;1,14..32,400&display=swap" rel="stylesheet">

    {# Bootstrap 5 #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">

    {# Application stylesheets #}
    <link rel="stylesheet" href="{{ base_url }}/assets/css/theme.css">
    <link rel="stylesheet" href="{{ base_url }}/assets/css/tailwind.css">

    {% block head_extra %}{% endblock %}
</head>
<body {% block body_attrs %}{% endblock %}>

    {% block body %}{% endblock %}

    {# Bootstrap JS #}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc4s9bIOgUxi8T/jzmQGn0FDFNZD62FW3k85k7u3p6A" crossorigin="anonymous" defer></script>

    {% block scripts %}{% endblock %}
</body>
</html>
