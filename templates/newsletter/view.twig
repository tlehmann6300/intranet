{% extends 'layouts/main.twig' %}
{% block title %}Newsletter ansehen – IBC Intranet{% endblock %}
{% block content %}
<div class="max-w-4xl mx-auto py-4">
    <div class="mb-4">
        <a href="{{ base_url }}/newsletter" class="text-sm text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200">
            ← Zurück zum Newsletter-Archiv
        </a>
    </div>

    {% if newsletter %}
    <div class="bg-white dark:bg-gray-900 rounded-2xl border border-gray-100 dark:border-gray-800 shadow-sm p-6 sm:p-8 mb-6">
        <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-50 mb-2">{{ newsletter.title }}</h1>
        {% if newsletter.created_at %}
        <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">
            {{ newsletter.created_at|date('d.m.Y') }}
            {% if newsletter.first_name or newsletter.last_name %}
            &middot; {{ newsletter.first_name }} {{ newsletter.last_name }}
            {% endif %}
        </p>
        {% endif %}

        <div class="mb-6">
            <a href="{{ base_url }}/api/newsletter/{{ newsletter.id }}/download"
                class="inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition text-sm no-underline">
                <i class="fas fa-download"></i>E-Mail herunterladen (.eml)
            </a>
        </div>

        {% if emailAttachments is defined and emailAttachments %}
        <div class="mb-6">
            <h2 class="text-lg font-semibold text-gray-800 dark:text-gray-100 mb-3">Anhänge</h2>
            <ul class="space-y-2">
                {% for att in emailAttachments %}
                <li>
                    <a href="{{ base_url }}/api/newsletter/{{ newsletter.id }}/download-attachment?index={{ att.index }}"
                        class="inline-flex items-center gap-2 text-sm text-blue-600 dark:text-blue-400 hover:underline no-underline">
                        <i class="fas fa-paperclip"></i>{{ att.filename }}
                    </a>
                </li>
                {% endfor %}
            </ul>
        </div>
        {% endif %}

        <div class="rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
            <iframe
                src="{{ base_url }}/newsletter/{{ newsletter.id }}/render"
                width="100%"
                height="600"
                frameborder="0"
                class="block"
                title="Newsletter Vorschau">
            </iframe>
        </div>
    </div>
    {% else %}
    <p class="text-red-500">Newsletter nicht gefunden.</p>
    {% endif %}
</div>
{% endblock %}
