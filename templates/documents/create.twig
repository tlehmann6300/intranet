{% extends 'layouts/main.twig' %}
{% block title %}Dokument hochladen – IBC Intranet{% endblock %}

{% block content %}
<div class="max-w-2xl mx-auto">

<div class="mb-6">
    <a href="/documents" class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200 mb-4">
        <i class="fas fa-arrow-left text-xs"></i> Zurück zu Dokumenten
    </a>
    <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-50">Dokument hochladen</h1>
    <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Erlaubte Formate: PDF, Word, Excel, PowerPoint, Text (max. 20 MB)</p>
</div>

{% if errors is not empty %}
<div class="mb-4 p-4 rounded-xl bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-700">
    {% for error in errors %}
    <p class="text-sm text-red-700 dark:text-red-300">{{ error }}</p>
    {% endfor %}
</div>
{% endif %}

<form method="POST" action="/documents/create" enctype="multipart/form-data" class="card rounded-xl p-6 space-y-5">
    <input type="hidden" name="csrf_token" value="{{ csrfToken }}">

    <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Titel *</label>
        <input type="text" name="title" required
               class="w-full px-3 py-2.5 bg-white border border-gray-300 text-gray-900 rounded-lg focus:ring-2 focus:ring-indigo-400/50 focus:border-indigo-400 dark:bg-gray-800 dark:border-gray-600 dark:text-white transition-colors">
    </div>

    <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Kategorie *</label>
        <select name="category" required
                class="w-full px-3 py-2.5 bg-white border border-gray-300 text-gray-900 rounded-lg focus:ring-2 focus:ring-indigo-400/50 focus:border-indigo-400 dark:bg-gray-800 dark:border-gray-600 dark:text-white transition-colors">
            <option value="">-- Bitte wählen --</option>
            {% for cat in categories %}
            <option value="{{ cat }}">{{ cat }}</option>
            {% endfor %}
        </select>
    </div>

    <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Beschreibung</label>
        <textarea name="description" rows="3"
                  class="w-full px-3 py-2.5 bg-white border border-gray-300 text-gray-900 rounded-lg focus:ring-2 focus:ring-indigo-400/50 focus:border-indigo-400 dark:bg-gray-800 dark:border-gray-600 dark:text-white transition-colors resize-none"
                  placeholder="Optionale Beschreibung des Dokuments…"></textarea>
    </div>

    <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Datei *</label>
        <input type="file" name="file" required accept=".pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt"
               class="w-full text-sm text-gray-700 dark:text-gray-300 file:mr-3 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100 dark:file:bg-indigo-900/30 dark:file:text-indigo-300">
        <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Wenn ein Dokument mit gleichem Titel und gleicher Kategorie existiert, wird eine neue Version erstellt.</p>
    </div>

    <div class="flex gap-3 pt-2">
        <button type="submit" class="flex-1 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg font-medium transition">
            <i class="fas fa-upload mr-2"></i> Hochladen
        </button>
        <a href="/documents" class="px-6 py-2.5 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-600 transition text-sm font-medium">
            Abbrechen
        </a>
    </div>
</form>

</div>
{% endblock %}
