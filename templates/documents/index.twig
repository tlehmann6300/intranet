{% extends 'layouts/main.twig' %}
{% block title %}Dokumente – IBC Intranet{% endblock %}

{% block content %}
<div class="max-w-7xl mx-auto">

<div class="mb-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
        <div class="flex items-center gap-3 mb-1">
            <div class="w-11 h-11 rounded-2xl bg-indigo-100 dark:bg-indigo-900/40 flex items-center justify-center shadow-sm">
                <i class="fas fa-folder-open text-indigo-600 dark:text-indigo-400 text-xl"></i>
            </div>
            <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-gray-50 tracking-tight">Dokumentenarchiv</h1>
        </div>
        <p class="text-gray-500 dark:text-gray-400 text-sm ml-14">Vereinssatzungen, Protokolle, Vorlagen und Verträge</p>
    </div>
    {% if canUpload %}
    <a href="/documents/create" class="inline-flex items-center gap-2 px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg text-sm font-medium transition">
        <i class="fas fa-upload"></i> Dokument hochladen
    </a>
    {% endif %}
</div>

{# Category filter #}
<div class="flex flex-wrap gap-2 mb-6">
    <a href="/documents"
       class="px-3 py-1.5 rounded-full text-sm font-medium transition {{ not selectedCategory ? 'bg-indigo-600 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200 dark:bg-gray-700 dark:text-gray-300 dark:hover:bg-gray-600' }}">
        Alle
    </a>
    {% for cat in categories %}
    <a href="/documents?category={{ cat|url_encode }}"
       class="px-3 py-1.5 rounded-full text-sm font-medium transition {{ selectedCategory == cat ? 'bg-indigo-600 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200 dark:bg-gray-700 dark:text-gray-300 dark:hover:bg-gray-600' }}">
        {{ cat }}
    </a>
    {% endfor %}
</div>

{% if grouped is empty %}
<div class="text-center py-16">
    <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-gray-100 dark:bg-gray-700 flex items-center justify-center">
        <i class="fas fa-folder text-3xl text-gray-300 dark:text-gray-500"></i>
    </div>
    <p class="text-gray-500 dark:text-gray-400">Keine Dokumente vorhanden</p>
    {% if canUpload %}
    <a href="/documents/create" class="mt-4 inline-flex items-center gap-2 text-indigo-600 hover:underline text-sm">
        <i class="fas fa-upload"></i> Erstes Dokument hochladen
    </a>
    {% endif %}
</div>
{% else %}
{% for category, docs in grouped %}
<section class="mb-8">
    <h2 class="text-lg font-semibold text-gray-800 dark:text-gray-200 mb-3 flex items-center gap-2">
        <i class="fas fa-tag text-indigo-500"></i> {{ category }}
        <span class="text-xs bg-indigo-100 text-indigo-700 dark:bg-indigo-900/30 dark:text-indigo-300 px-2 py-0.5 rounded-full">{{ docs|length }}</span>
    </h2>
    <div class="card rounded-xl shadow-sm divide-y divide-gray-50 dark:divide-gray-700/50">
        {% for doc in docs %}
        <div class="flex items-center gap-4 px-5 py-4 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
            <div class="flex-shrink-0">
                <div class="w-10 h-10 rounded-xl bg-indigo-50 dark:bg-indigo-900/30 flex items-center justify-center">
                    <i class="fas fa-file-alt text-indigo-500"></i>
                </div>
            </div>
            <div class="flex-1 min-w-0">
                <a href="/documents/{{ doc.id }}" class="font-medium text-gray-900 dark:text-gray-100 hover:text-indigo-600 dark:hover:text-indigo-400 truncate block">
                    {{ doc.title }}
                </a>
                {% if doc.description %}
                <p class="text-xs text-gray-500 dark:text-gray-400 truncate">{{ doc.description }}</p>
                {% endif %}
                <div class="flex gap-3 text-xs text-gray-400 dark:text-gray-500 mt-0.5">
                    <span>v{{ doc.version }}</span>
                    <span>{{ doc.uploaded_at|date('d.m.Y') }}</span>
                    {% if doc.firstname %}<span>{{ doc.firstname }} {{ doc.lastname }}</span>{% endif %}
                </div>
            </div>
            <div class="flex gap-2 flex-shrink-0">
                <a href="/documents/{{ doc.id }}/download"
                   class="inline-flex items-center gap-1 px-3 py-1.5 bg-indigo-50 hover:bg-indigo-100 dark:bg-indigo-900/30 dark:hover:bg-indigo-900/50 text-indigo-700 dark:text-indigo-300 rounded-lg text-xs font-medium transition">
                    <i class="fas fa-download"></i> Download
                </a>
            </div>
        </div>
        {% endfor %}
    </div>
</section>
{% endfor %}
{% endif %}

</div>
{% endblock %}
